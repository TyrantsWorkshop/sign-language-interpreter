# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Model Paths
MODEL_PATH=./saved_models/sign_language_model.pt
EMOTION_MODEL_PATH=./saved_models/emotion_model.pt
GESTURE_MODEL_PATH=./saved_models/gesture_model.pt
LABEL_MAP_PATH=./saved_models/label_map.pkl

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=False
WORKERS=1

# Device Configuration
DEVICE=cuda
CUDA_VISIBLE_DEVICES=0

# Training Configuration
BATCH_SIZE=32
LEARNING_RATE=0.001
NUM_EPOCHS=50
GRADIENT_CLIP=1.0

# Frontend Configuration
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# TTS Configuration
TTS_PROVIDER=elevenlabs
TTS_VOICE_ID=your_voice_id
TTS_MODEL=eleven_monolingual_v1

# LLM Configuration
LLM_MODEL=gpt-3.5-turbo
LLM_MAX_TOKENS=100
LLM_TEMPERATURE=0.7
